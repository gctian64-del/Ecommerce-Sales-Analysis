-- ============================================================
-- FILE    : 01_create_tables.sql
-- PROJECT : E-Commerce Sales Analysis (Olist Dataset)
-- AUTHOR  : Pavithra Panneerselvam
-- ============================================================
--
-- PURPOSE
-- -------
-- Creates the 5 core staging tables that mirror the Olist
-- dataset schema. Olist is a Brazilian e-commerce marketplace
-- that connects small merchants to customers across Brazil.
--
-- WHY MULTIPLE TABLES?
-- --------------------
-- Unlike the Telecom project (single flat table), real-world
-- business data is always relational. Olist stores orders,
-- customers, products, sellers, and payments in separate
-- tables linked by keys. This mirrors how data lives in
-- actual company databases (ERP, CRM, payment systems).
--
-- Analysing this data requires JOINs — the most important
-- and most tested SQL skill in BA interviews.
--
-- TABLE RELATIONSHIPS
-- -------------------
--   orders          ─── order_id ──► order_items
--   orders          ─── customer_id ──► customers
--   order_items     ─── product_id ──► products
--   order_items     ─── seller_id ──► sellers
--   orders          ─── order_id ──► order_payments
--
-- NEXT STEP
-- ---------
-- After running this script, execute 02_insert_data.sql.
-- ============================================================


-- Core orders table — one row per order
CREATE TABLE orders (
    order_id                VARCHAR(40),
    customer_id             VARCHAR(40),
    order_status            VARCHAR(20),    -- delivered, shipped, cancelled, etc.
    order_purchase_ts       TIMESTAMP,      -- when customer placed the order
    order_approved_ts       TIMESTAMP,      -- when payment was approved
    order_delivered_ts      TIMESTAMP,      -- when customer received the order
    order_estimated_ts      TIMESTAMP       -- estimated delivery date
);

-- Customers — one row per unique customer
CREATE TABLE customers (
    customer_id             VARCHAR(40),
    customer_city           VARCHAR(50),
    customer_state          VARCHAR(5)      -- Brazilian state code (SP, RJ, MG...)
);

-- Order line items — one row per product within an order
CREATE TABLE order_items (
    order_id                VARCHAR(40),
    order_item_id           INT,            -- line number within the order (1, 2, 3...)
    product_id              VARCHAR(40),
    seller_id               VARCHAR(40),
    price                   NUMERIC(10, 2), -- item price in BRL
    freight_value           NUMERIC(10, 2)  -- shipping cost for this item
);

-- Products — one row per unique product
CREATE TABLE products (
    product_id              VARCHAR(40),
    product_category        VARCHAR(60)     -- e.g. electronics, furniture, beauty
);

-- Payments — one row per payment transaction (orders can have multiple)
CREATE TABLE order_payments (
    order_id                VARCHAR(40),
    payment_sequential      INT,            -- payment number if split across methods
    payment_type            VARCHAR(20),    -- credit_card, boleto, voucher, debit_card
    payment_installments    INT,            -- number of installments chosen
    payment_value           NUMERIC(10, 2)  -- amount paid in this transaction
);

